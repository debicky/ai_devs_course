# --- Run ---
puts 'Suspects: data/suspects.json (from people task output; run bin/run first to populate)'
step('Loading suspects') do
  suspects_loader.call.tap { |s| print "(#{s.size} suspects) " }
end

loop do
  result = step('Running findhim agent') do
    task.call do |iteration, response, tool_results|
      tool_results = Array(tool_results)
      tool_calls = Array(response['tool_calls'])
      max = Tasks::FindHimTask::MAX_ITERATIONS
      if tool_results.any?
        tool_results.each do |tool_result|
          tool_name = tool_result[:name].to_s
          args = tool_result[:arguments]
          result_summary = format_tool_result(tool_name, tool_result[:result])
          puts "  [#{iteration}/#{max}] #{format_tool_call(tool_name, args)}"
          puts "    ← #{result_summary}" if result_summary
        end
      elsif tool_calls.empty?
        content = response['content'].to_s.strip
        puts "  [#{iteration}/#{max}] Assistant reply (no tool calls)"
        puts "    #{content}" unless content.empty?
      else
        puts "  [#{iteration}/#{max}] Assistant prepared tool calls"
      end
    end
  end

  if result.is_a?(Hash) && result[:incorrect_person]
    name = result[:incorrect_person][:name]
    surname = result[:incorrect_person][:surname]
    submitted = result[:answer] || result
    puts "\n  Verify rejected answer (server: check name, surname, access level, power plant code):"
    puts "    Submitted: #{submitted.inspect}"
    puts "    Error: #{result[:error]}"
    puts '  Optional: remove this suspect and retry? The failure might be wrong access level or plant code, not the person.'
    removed = remove_suspect_from_file(SUSPECTS_PATH, name: name, surname: surname)
    if removed.positive?
      puts "  Removed #{name} #{surname} from data/suspects.json (#{removed} entry), retrying..."
      remaining = JSON.parse(File.read(SUSPECTS_PATH)).size
      if remaining.zero?
        puts '  No suspects left in data/suspects.json; cannot retry.'
        exit 1
      end
      next
    end
    puts "  Suspect #{name} #{surname} not found in suspects file; cannot retry."
    exit 1
  end

  puts "\nVerification result:"
  puts JSON.pretty_generate(result[:verification] || result)
  break
end
