#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../../config/environment'

$stdout.sync = true

def required_env!(name)
  value = ENV[name].to_s.strip
  return value unless value.empty?

  raise ArgumentError, "Missing required environment variable: #{name}"
end

api_key = required_env!('AG3NTS_API_KEY')

# gpt-4o-mini is sufficient for interpreting short radio navigation hints
DEFAULT_MODEL = 'gpt-4o-mini'
model = ENV.fetch('LLM_MODEL', DEFAULT_MODEL)

puts "→ Lesson 24: goingthere (model: #{model})"
puts '→ Navigate the rocket through a 3×12 grid to reach Grudziądz'
puts

http_client = Clients::HttpClient.new(open_timeout: 15, read_timeout: 30)
hub_client  = Clients::HubClient.new(http_client: http_client)

openrouter_key = ENV['OPENROUTER_API_KEY'].to_s.strip
openai_key     = ENV['OPENAI_API_KEY'].to_s.strip

llm_api_key, llm_base_url =
  if !openrouter_key.empty?
    [openrouter_key, 'https://openrouter.ai/api/v1']
  elsif !openai_key.empty?
    [openai_key, Clients::LlmClient::OPENAI_BASE_URL]
  else
    raise ArgumentError, 'Either OPENROUTER_API_KEY or OPENAI_API_KEY is required'
  end

llm_client = Clients::LlmClient.new(
  http_client: http_client,
  api_key: llm_api_key,
  model: model,
  base_url: llm_base_url
)

frequency_scanner = Services::Goingthere::FrequencyScanner.new(
  http_client: http_client,
  api_key: api_key
)

hint_interpreter = Services::Goingthere::HintInterpreter.new(
  http_client: http_client,
  llm_client: llm_client,
  api_key: api_key
)

runner = Services::Goingthere::Runner.new(
  hub_client: hub_client,
  frequency_scanner: frequency_scanner,
  hint_interpreter: hint_interpreter
)

task = Tasks::GoingtherTask.new(runner: runner)

result = task.call

puts
puts '=== RESULT ==='
if result[:flag]
  puts "Flag: #{result[:flag]}"
else
  puts 'No flag obtained.'
end
