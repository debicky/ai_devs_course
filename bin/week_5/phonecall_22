#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../../config/environment'

def required_env!(name)
  value = ENV[name].to_s.strip
  return value unless value.empty?

  raise ArgumentError, "Missing required environment variable: #{name}"
end

required_env!('AG3NTS_API_KEY')
required_env!('OPENAI_API_KEY')
# ELEVENLABS_API_KEY is optional — falls back to OpenAI TTS

$stdout.sync = true

puts '→ Lesson 22: phonecall'
puts '→ Phone call to road monitoring operator'
puts

http_client = Clients::HttpClient.new(open_timeout: 30, read_timeout: 180)
hub_client  = Clients::HubClient.new(http_client: http_client)

llm_client = Clients::LlmClient.new(
  http_client: http_client,
  api_key: ENV.fetch('OPENAI_API_KEY'),
  model: ENV.fetch('LLM_MODEL', 'gpt-4o')
)

# ── TTS client (ElevenLabs) ──────────────────────────────────────────────

tts_client = Object.new

# Re-encode through ffmpeg → mono MP3, strip TTS metadata
tts_client.define_singleton_method(:reencode) do |audio_bytes|
  require 'tmpdir'
  Dir.mktmpdir('phonecall') do |dir|
    inp = File.join(dir, 'in.mp3')
    out = File.join(dir, 'out.mp3')
    File.binwrite(inp, audio_bytes)
    system('ffmpeg', '-y', '-i', inp,
           '-ac', '1', '-ar', '24000', '-b:a', '96k',
           '-af', 'highpass=f=200,lowpass=f=3400',
           out, out: File::NULL, err: File::NULL) or raise 'ffmpeg failed'
    File.binread(out)
  end
end

tts_client.define_singleton_method(:synthesize) do |text, voice: 'onwK4e9ZLuTAKqWW03F9'|
  elevenlabs_key = ENV['ELEVENLABS_API_KEY'].to_s.strip
  use_openai = elevenlabs_key.empty?

  unless use_openai
    begin
      voice_name = { 'pNInz6obpgDQGcFmaJgB' => 'Adam', 'onwK4e9ZLuTAKqWW03F9' => 'Daniel' }[voice] || voice
      $stdout.puts "  [TTS] elevenlabs/#{voice_name} text=#{text[0..80]}"

      uri = URI("https://api.elevenlabs.io/v1/text-to-speech/#{voice}")
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      http.read_timeout = 60
      request = Net::HTTP::Post.new(uri.path)
      request['xi-api-key'] = elevenlabs_key
      request['Content-Type'] = 'application/json'
      request['Accept'] = 'audio/mpeg'
      request.body = JSON.generate(
        text: text,
        model_id: 'eleven_multilingual_v2',
        language_code: 'pl',
        voice_settings: { stability: 0.35, similarity_boost: 0.80, style: 0.3, use_speaker_boost: true }
      )
      response = http.request(request)
      if response.is_a?(Net::HTTPSuccess)
        next reencode(response.body)
      else
        $stdout.puts "  [TTS] ElevenLabs failed (#{response.code}), falling back to OpenAI"
        use_openai = true
      end
    rescue StandardError => e
      $stdout.puts "  [TTS] ElevenLabs error: #{e.message[0..100]}, falling back to OpenAI"
      use_openai = true
    end
  end

  # OpenAI TTS fallback
  $stdout.puts "  [TTS] openai/onyx text=#{text[0..80]}"
  oai_uri = URI('https://api.openai.com/v1/audio/speech')
  oai_http = Net::HTTP.new(oai_uri.host, oai_uri.port)
  oai_http.use_ssl = true
  oai_http.read_timeout = 60
  oai_req = Net::HTTP::Post.new(oai_uri.path)
  oai_req['Authorization'] = "Bearer #{ENV.fetch('OPENAI_API_KEY')}"
  oai_req['Content-Type'] = 'application/json'
  oai_req.body = JSON.generate(model: 'gpt-4o-mini-tts', input: text, voice: 'ash',
                               instructions: 'Speak naturally in Polish, like a real person on a phone call. Casual, confident male voice.',
                               response_format: 'mp3')
  oai_resp = oai_http.request(oai_req)
  raise "OpenAI TTS failed (#{oai_resp.code}): #{oai_resp.body[0..200]}" unless oai_resp.is_a?(Net::HTTPSuccess)

  reencode(oai_resp.body)
end

# ── Whisper client ────────────────────────────────────────────────────────

whisper_client = Object.new
whisper_client.define_singleton_method(:transcribe) do |file_path|
  uri = URI('https://api.openai.com/v1/audio/transcriptions')
  boundary = "----RubyFormBoundary#{SecureRandom.hex(16)}"

  file_data = File.binread(file_path)
  body = []
  body << "--#{boundary}\r\n"
  body << "Content-Disposition: form-data; name=\"file\"; filename=\"audio.mp3\"\r\n"
  body << "Content-Type: audio/mpeg\r\n\r\n"
  body << file_data
  body << "\r\n--#{boundary}\r\n"
  body << "Content-Disposition: form-data; name=\"model\"\r\n\r\n"
  body << 'whisper-1'
  body << "\r\n--#{boundary}\r\n"
  body << "Content-Disposition: form-data; name=\"language\"\r\n\r\n"
  body << 'pl'
  body << "\r\n--#{boundary}--\r\n"

  payload = body.join

  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.read_timeout = 120

  request = Net::HTTP::Post.new(uri.path)
  request['Authorization'] = "Bearer #{ENV.fetch('OPENAI_API_KEY')}"
  request['Content-Type'] = "multipart/form-data; boundary=#{boundary}"
  request.body = payload

  response = http.request(request)
  result = JSON.parse(response.body)
  result['text'] || result.to_s
end

# ── Run ───────────────────────────────────────────────────────────────────

runner = Services::Phonecall::Runner.new(
  hub_client: hub_client,
  tts_client: tts_client,
  whisper_client: whisper_client,
  llm_client: llm_client
)
task = Tasks::PhonecallTask.new(runner: runner)

result = task.call

puts
puts '=== RESULT ==='
if result[:flag]&.match?(/\{FLG:/)
  puts "Flag: #{result[:flag]}"
else
  puts 'No flag obtained.'
end
