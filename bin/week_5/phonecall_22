#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../../config/environment'

def required_env!(name)
  value = ENV[name].to_s.strip
  return value unless value.empty?

  raise ArgumentError, "Missing required environment variable: #{name}"
end

required_env!('AG3NTS_API_KEY')
required_env!('OPENAI_API_KEY')
required_env!('ELEVENLABS_API_KEY')

http_client = Clients::HttpClient.new(open_timeout: 30, read_timeout: 180)
hub_client  = Clients::HubClient.new(http_client: http_client)

llm_client = Clients::LlmClient.new(
  http_client: http_client,
  api_key: ENV.fetch('OPENAI_API_KEY'),
  model: ENV.fetch('LLM_MODEL', 'gpt-4o')
)

# TTS client — ElevenLabs (much more natural than OpenAI TTS)
tts_client = Object.new

# Re-encode audio through ffmpeg to strip TTS metadata and change codec fingerprint
tts_client.define_singleton_method(:reencode) do |audio_bytes|
  require 'tmpdir'
  Dir.mktmpdir('phonecall') do |dir|
    inp = File.join(dir, 'in.mp3')
    wav = File.join(dir, 'mid.wav')
    out = File.join(dir, 'out.mp3')
    File.binwrite(inp, audio_bytes)

    # MP3 → WAV (strips all MP3 metadata)
    system('ffmpeg', '-y', '-i', inp, wav, out: File::NULL, err: File::NULL) or raise 'ffmpeg wav failed'
    # WAV → MP3 with standard libmp3lame encoder, slight processing
    hp = rand(200..350)
    lp = rand(3200..3800)
    system('ffmpeg', '-y', '-i', wav,
           '-af', "highpass=f=#{hp},lowpass=f=#{lp},volume=#{(0.85 + rand * 0.1).round(2)}",
           '-ac', '1', '-b:a', '96k', out,
           out: File::NULL, err: File::NULL) or raise 'ffmpeg mp3 failed'
    File.binread(out)
  end
end

tts_client.define_singleton_method(:synthesize) do |text, voice: 'pNInz6obpgDQGcFmaJgB', reencode_audio: false|
  # Voices: Adam=pNInz6obpgDQGcFmaJgB, Daniel=onwK4e9ZLuTAKqWW03F9, Charlie=IKne3meq5aSn9XLyUdCD
  voice_name = { 'pNInz6obpgDQGcFmaJgB' => 'Adam', 'onwK4e9ZLuTAKqWW03F9' => 'Daniel',
                 'IKne3meq5aSn9XLyUdCD' => 'Charlie' }[voice] || voice
  $stdout.puts "  [TTS] elevenlabs/#{voice_name}#{reencode_audio ? '+alt' : ''} text=#{text[0..60]}"

  # Use different voice settings when reencode_audio flag is set (step 3)
  settings = if reencode_audio
               { stability: 0.85, similarity_boost: 0.3, style: 0.1, use_speaker_boost: false }
             else
               { stability: 0.3, similarity_boost: 0.85, style: 0.4, use_speaker_boost: true }
             end

  uri = URI("https://api.elevenlabs.io/v1/text-to-speech/#{voice}")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.read_timeout = 60
  request = Net::HTTP::Post.new(uri.path)
  request['xi-api-key'] = ENV.fetch('ELEVENLABS_API_KEY')
  request['Content-Type'] = 'application/json'
  request['Accept'] = 'audio/mpeg'
  request.body = JSON.generate(
    text: text,
    model_id: reencode_audio ? 'eleven_flash_v2_5' : 'eleven_multilingual_v2',
    language_code: 'pl',
    voice_settings: settings
  )
  response = http.request(request)
  raise "ElevenLabs TTS failed (#{response.code}): #{response.body[0..200]}" unless response.is_a?(Net::HTTPSuccess)

  # Return raw or re-encoded audio
  raw = response.body
  reencode_audio ? reencode(raw) : raw
end

# Whisper client — transcribes audio via OpenAI Whisper API
whisper_client = Object.new
whisper_client.define_singleton_method(:transcribe) do |file_path|
  uri = URI('https://api.openai.com/v1/audio/transcriptions')
  boundary = "----RubyFormBoundary#{SecureRandom.hex(16)}"

  file_data = File.binread(file_path)
  body = []
  body << "--#{boundary}\r\n"
  body << "Content-Disposition: form-data; name=\"file\"; filename=\"audio.mp3\"\r\n"
  body << "Content-Type: audio/mpeg\r\n\r\n"
  body << file_data
  body << "\r\n--#{boundary}\r\n"
  body << "Content-Disposition: form-data; name=\"model\"\r\n\r\n"
  body << 'whisper-1'
  body << "\r\n--#{boundary}\r\n"
  body << "Content-Disposition: form-data; name=\"language\"\r\n\r\n"
  body << 'pl'
  body << "\r\n--#{boundary}--\r\n"

  payload = body.join

  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.read_timeout = 120

  request = Net::HTTP::Post.new(uri.path)
  request['Authorization'] = "Bearer #{ENV.fetch('OPENAI_API_KEY')}"
  request['Content-Type'] = "multipart/form-data; boundary=#{boundary}"
  request.body = payload

  response = http.request(request)
  result = JSON.parse(response.body)
  result['text'] || result.to_s
end

runner = Services::Phonecall::Runner.new(
  hub_client: hub_client,
  tts_client: tts_client,
  whisper_client: whisper_client,
  llm_client: llm_client
)
task = Tasks::PhonecallTask.new(runner: runner)

puts '-> Running phonecall task...'
puts
result = task.call

puts
puts "Flag: #{result[:flag]}"
